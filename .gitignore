# Python bytecode and tool caches
__pycache__/
*.py[cod]
.pytest_cache/
.pytest_tmp/
tests/_tmp_databases/
tests/_tmp_pytest_env/
.mypy_cache/
.ruff_cache/

# Virtual environments and local environment files
.venv/
venv/
.env
.env.*

# Runtime-generated data and logs
data/*
!data/.gitkeep
logs/*
!logs/.gitkeep
attachments/*
!attachments/.gitkeep

# IDE and operating-system files
.idea/
.vscode/
.DS_Store
Thumbs.db
